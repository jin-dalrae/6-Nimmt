{
  "name": "sfboardgames",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SFboardgames — real-time multiplayer 6 Nimmt! on Cloudflare Pages + Workers",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "build": "vite build",
    "build:pages": "vite build && node scripts/build-pages.mjs",
    "deploy": "vite build && wrangler deploy",
    "deploy:pages": "npm run build:pages && wrangler pages deploy dist/pages-out --project-name=nimmt6 --branch=main --commit-dirty=true",
    "deploy:all": "npm run deploy && npm run deploy:pages",
    "check": "tsc --noEmit",
    "preview": "vite preview"
  },
  "license": "MIT",
  "dependencies": {
    "partyserver": "^0.0.66",
    "partysocket": "^1.1.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.4",
    "@cloudflare/workers-types": "^4.20250409.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.2.5",
    "wrangler": "^4.9.1"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260714.1": true
  }
}
